worker_processes auto;
events { worker_connections 1024; }

http {
  include /etc/nginx/mime.types;
  default_type application/octet-stream;
  server_tokens off;
  sendfile on;
  gzip on;
  gzip_types text/plain text/css application/javascript application/json;

  # Rate limiting
  limit_req_zone $binary_remote_addr zone=login:10m rate=10r/m;
  limit_req_zone $binary_remote_addr zone=api:10m   rate=60r/m;
  limit_req_zone $binary_remote_addr zone=ai:10m    rate=8r/m;

  # Logging
  access_log /var/log/nginx/access.log;
  error_log  /var/log/nginx/error.log;

  # Docker's internal DNS — re-resolves every 10s so nginx picks up new container IPs after rebuilds
  resolver 127.0.0.11 valid=1s ipv6=off;

  # HTTP: serve ACME challenge; redirect everything else to HTTPS
  server {
    listen 80 default_server;
    server_name ${DOMAIN};

    location /.well-known/acme-challenge/ {
      root /var/www/certbot;
    }

    location / {
      return 301 https://$host$request_uri;
    }
  }

  # HTTPS
  server {
    listen 443 ssl default_server;
    server_name ${DOMAIN};

    ssl_certificate     ${CERT_DIR}/fullchain.pem;
    ssl_certificate_key ${CERT_DIR}/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 10m;

    add_header Strict-Transport-Security "max-age=15768000; includeSubDomains" always;

    set $webapp http://webapp:3000;

    location = /health {
      proxy_pass         $webapp/health;
      access_log         off;
      proxy_read_timeout 10s;
    }

    location = /api/login {
      limit_req zone=login burst=5 nodelay;
      proxy_pass         $webapp;
      proxy_http_version 1.1;
      proxy_set_header   Host              $host;
      proxy_set_header   X-Real-IP         $remote_addr;
      proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
      proxy_set_header   X-Forwarded-Proto https;
      proxy_read_timeout 30s;
    }

    location ~ ^/api/(ai|langchain)/ {
      limit_req zone=ai burst=4 nodelay;
      proxy_pass         $webapp;
      proxy_http_version 1.1;
      proxy_set_header   Host              $host;
      proxy_set_header   X-Real-IP         $remote_addr;
      proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
      proxy_set_header   X-Forwarded-Proto https;
      proxy_set_header   Connection        "";
      proxy_read_timeout 200s;
      proxy_send_timeout 200s;
      proxy_connect_timeout 10s;
      proxy_buffering    off;
      proxy_cache        off;
    }

    location ~ ^/api/assets/scan {
      limit_req zone=api burst=5 nodelay;
      proxy_pass         $webapp;
      proxy_http_version 1.1;
      proxy_set_header   Host              $host;
      proxy_set_header   X-Real-IP         $remote_addr;
      proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
      proxy_set_header   X-Forwarded-Proto https;
      proxy_set_header   Connection        "";
      proxy_read_timeout 30s;
    }

    location /api/ {
      limit_req zone=api burst=20 nodelay;
      proxy_pass         $webapp;
      proxy_http_version 1.1;
      proxy_set_header   Host              $host;
      proxy_set_header   X-Real-IP         $remote_addr;
      proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
      proxy_set_header   X-Forwarded-Proto https;
      proxy_set_header   Connection        "";
      proxy_read_timeout 90s;
    }

    location / {
      proxy_pass         $webapp;
      proxy_http_version 1.1;
      proxy_set_header   Upgrade           $http_upgrade;
      proxy_set_header   Connection        "upgrade";
      proxy_set_header   Host              $host;
      proxy_set_header   X-Real-IP         $remote_addr;
      proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
      proxy_set_header   X-Forwarded-Proto https;
      proxy_cache_bypass $http_upgrade;
      proxy_read_timeout 90s;
    }
  }
}
