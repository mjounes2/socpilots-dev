# ================================================================
# SOC PILOTS — Customer Environment Configuration
# ================================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.template .env
#   2. Fill in ALL values marked with <CHANGE_THIS>
#   3. Never share or commit the .env file
# ================================================================

# ────────────────────────────────────────────────────────────────
# [1] WEBAPP SETTINGS
# ────────────────────────────────────────────────────────────────

# Port the webapp runs on (default 3000 — do not change unless needed)
PORT=3000

# Environment
NODE_ENV=production

# ────────────────────────────────────────────────────────────────
# [2] WAZUH — OpenSearch Configuration
# ────────────────────────────────────────────────────────────────
# OpenSearch is the data backend for Wazuh alerts
# Default OpenSearch port: 9200
# Default credentials: admin / admin (change in production!)
#
# Examples:
#   OPENSEARCH_URL=https://192.168.1.100:9200
#   OPENSEARCH_URL=https://wazuh.mycustomer.com:9200

OPENSEARCH_URL=https://<WAZUH_SERVER_IP_OR_DOMAIN>:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASS=<WAZUH_OPENSEARCH_PASSWORD>

# Wazuh alert index pattern (do not change unless custom)
WAZUH_INDEX=wazuh-alerts-*

# ────────────────────────────────────────────────────────────────
# [3] THEHIVE — Case Management Configuration
# ────────────────────────────────────────────────────────────────
# TheHive REST API
# Port 9000 (default) or 443 (if behind reverse proxy)
#
# To get your API key:
#   TheHive → Settings → API Keys → Create API Key
#
# Examples:
#   THEHIVE_URL=http://192.168.1.101:9000
#   THEHIVE_URL=https://thehive.mycustomer.com

THEHIVE_URL=https://<THEHIVE_SERVER_IP_OR_DOMAIN>
THEHIVE_API_KEY=<THEHIVE_API_KEY>

# ────────────────────────────────────────────────────────────────
# [4] N8N — AI Webhook Configuration
# ────────────────────────────────────────────────────────────────
# n8n webhook URL — used for:
#   - AI Copilot (Mistral AI)
#   - Vulnerability queries
#   - Threat hunt AI analysis
#   - Correlation AI reports
#   - Executive reports
#
# The webhook path must match your n8n workflow webhook node path
#
# Examples:
#   N8N_WEBHOOK_URL=http://192.168.1.102:5678/webhook/socpilots
#   N8N_WEBHOOK_URL=http://n8n.mycustomer.com:5678/webhook/soc-webhook

N8N_WEBHOOK_URL=http://<N8N_SERVER_IP_OR_DOMAIN>:5678/webhook/<WEBHOOK_PATH>

# ────────────────────────────────────────────────────────────────
# [5] SOC PILOTS — User Accounts
# ────────────────────────────────────────────────────────────────
# Format: username:password:role,username2:password2:role2
# Roles: admin, analyst, viewer
#
# IMPORTANT: Use strong passwords in production!
# Example:
#   SOC_USERS=admin:MyStr0ngP@ss!:admin,analyst1:An@lyst2024:analyst

SOC_USERS=admin:<ADMIN_PASSWORD>:admin,analyst:<ANALYST_PASSWORD>:analyst

# ────────────────────────────────────────────────────────────────
# [6] CORS (Optional)
# ────────────────────────────────────────────────────────────────
# Allowed origins for CORS (comma-separated)
# Add your public domain if accessed from browser
ALLOWED_ORIGINS=http://localhost,http://localhost:3000
