PORT=3000

# Wazuh OpenSearch
OPENSEARCH_URL=https://YOUR_WAZUH_SERVER:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASS=YOUR_OPENSEARCH_PASSWORD
WAZUH_INDEX=wazuh-alerts-*

# TheHive
THEHIVE_URL=https://YOUR_THEHIVE_URL
THEHIVE_API_KEY=YOUR_THEHIVE_API_KEY

# n8n (AI, Hunt, Detection Rules, Reports)
N8N_WEBHOOK_URL=http://YOUR_N8N_SERVER:5678/webhook/socpilots
N8N_INVESTIGATION_URL=http://YOUR_N8N_SERVER:5678/webhook/socpilots-investigation

# Users: username:password:role  (comma-separated)
SOC_USERS=admin:CHANGE_ME:admin,analyst:CHANGE_ME:analyst

# PostgreSQL
PG_HOST=postgres
PG_PORT=5432
PG_DATABASE=socpilots
PG_USER=socpilots
PG_PASSWORD=CHANGE_ME
