# ═══════════════════════════════════════════════════════════════════
#  SOCPilots Unified Stack — Single Environment File
#  All services (webapp, mcp-wazuh, thehive-mcp, n8n, postgres) read
#  from this one file via docker-compose environment blocks.
#
#  Setup:
#    cp .env.example .env
#    nano .env          ← fill in every CHANGE_ME value
#    docker compose up -d --build
# ═══════════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────────
# Public IP or hostname of THIS server (used for n8n webhook base URL)
SERVER_IP=YOUR_SERVER_PUBLIC_IP

# ── PostgreSQL ───────────────────────────────────────────────────────
PG_DATABASE=socpilots
PG_USER=socpilots
PG_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── SOCPilots Webapp ─────────────────────────────────────────────────
# Users: username:password:role  (comma-separated, role = admin|analyst)
SOC_USERS=admin:CHANGE_ME:admin,analyst:CHANGE_ME:analyst

# ── Wazuh / OpenSearch ───────────────────────────────────────────────
# Wazuh runs on a SEPARATE server — set its hostname/IP here
WAZUH_HOST=YOUR_WAZUH_SERVER_HOSTNAME
WAZUH_PORT=55000
WAZUH_USER=wazuh-wui
WAZUH_PASS=CHANGE_ME_WAZUH_API_PASSWORD

WAZUH_INDEXER_HOST=YOUR_WAZUH_SERVER_HOSTNAME
WAZUH_INDEXER_PORT=9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASS=CHANGE_ME_INDEXER_PASSWORD

# OpenSearch URL consumed by the webapp (same host as indexer)
OPENSEARCH_URL=https://YOUR_WAZUH_SERVER_HOSTNAME:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASS=CHANGE_ME_INDEXER_PASSWORD
WAZUH_INDEX=wazuh-alerts-*

# ── TheHive ──────────────────────────────────────────────────────────
THEHIVE_URL=https://YOUR_THEHIVE_URL
THEHIVE_API_KEY=YOUR_THEHIVE_API_KEY

# ── n8n ──────────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Webhook URLs used by the webapp to reach n8n
# Using internal Docker service name so traffic never leaves the stack
N8N_WEBHOOK_URL=http://n8n:5678/webhook/socpilots
N8N_INVESTIGATION_URL=http://n8n:5678/webhook/socpilots-investigation

# ── Wazuh MCP Auth ───────────────────────────────────────────────────
# Auth mode: bearer (recommended) or none
WAZUH_MCP_AUTH_MODE=bearer
# Generate with: openssl rand -hex 32
AUTH_SECRET_KEY=CHANGE_ME_RUN_openssl_rand_hex_32
# Optional static API key (leave blank to auto-generate on startup)
MCP_API_KEY=

# ── Build metadata ───────────────────────────────────────────────────
BUILD_DATE=unknown
