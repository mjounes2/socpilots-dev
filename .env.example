# ═══════════════════════════════════════════════════════════
#  SOCPilots Unified Stack — Environment Variables
#  Copy this file to .env and fill in your real values:
#    cp .env.example .env && nano .env
# ═══════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────
# Your server's public IP or hostname (used for n8n webhook URL)
SERVER_IP=YOUR_SERVER_PUBLIC_IP

# ── PostgreSQL ───────────────────────────────────────────────
PG_DATABASE=socpilots
PG_USER=socpilots
PG_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── TheHive ──────────────────────────────────────────────────
THEHIVE_URL=https://YOUR_THEHIVE_URL
THEHIVE_API_KEY=YOUR_THEHIVE_API_KEY

# ── Wazuh MCP ────────────────────────────────────────────────
# Set these to the hostname/IP of your Wazuh server (NOT the SOCPilots server)
WAZUH_HOST=YOUR_WAZUH_SERVER_HOSTNAME
WAZUH_INDEXER_HOST=YOUR_WAZUH_SERVER_HOSTNAME
WAZUH_PORT=55000
WAZUH_INDEXER_PORT=9200
WAZUH_MCP_AUTH_MODE=bearer

# ── n8n ──────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Build metadata (optional) ────────────────────────────────
BUILD_DATE=unknown
