# ═══════════════════════════════════════════════════════════════════
#  SOCPilots — Environment Template
#  Copy to .env and fill in all values before deploying.
#  Command: cp .env.example .env && nano .env
# ═══════════════════════════════════════════════════════════════════

# ── HTTPS / TLS ──────────────────────────────────────────────────────
# Domain name for SSL/TLS certificate and nginx server_name.
# Set to your public domain. After deploying run:
#   bash scripts/init-letsencrypt.sh   ← issues a free Let's Encrypt cert
# Until then nginx uses a self-signed cert (browser security warning).
DOMAIN=your.domain.com

# Email for Let's Encrypt registration and expiry notices.
CERTBOT_EMAIL=your@email.com

# ── Server ───────────────────────────────────────────────────────────
# The IP address of this server (shown in n8n editor URL)
SERVER_IP=YOUR_SERVER_IP

# ── PostgreSQL ───────────────────────────────────────────────────────
PG_DATABASE=socpilots
PG_USER=socpilots
PG_PASSWORD=CHANGE_ME_strong_password_here

# ── SOCPilots Webapp ─────────────────────────────────────────────────
# Format: username:password:role  (roles: admin, analyst)
SOC_USERS=admin:CHANGE_ME:admin,analyst:CHANGE_ME:analyst

# ── Wazuh / OpenSearch ───────────────────────────────────────────────
WAZUH_HOST=YOUR_WAZUH_MANAGER_IP
WAZUH_PORT=55000
WAZUH_USER=wazuh-wui
WAZUH_PASS=YOUR_WAZUH_PASSWORD

WAZUH_INDEXER_HOST=YOUR_WAZUH_INDEXER_IP
WAZUH_INDEXER_PORT=9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASS=YOUR_INDEXER_PASSWORD

OPENSEARCH_URL=https://YOUR_WAZUH_INDEXER_IP:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASS=YOUR_INDEXER_PASSWORD
WAZUH_INDEX=wazuh-alerts-*

# ── TheHive ──────────────────────────────────────────────────────────
THEHIVE_URL=https://your-thehive-instance.com
THEHIVE_API_KEY=YOUR_THEHIVE_API_KEY

# ── n8n ──────────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME_strong_password_here
N8N_WEBHOOK_URL=http://n8n:5678/webhook/socpilots
N8N_INVESTIGATION_URL=http://n8n:5678/webhook/socpilots-investigation

# ── Wazuh MCP Auth ───────────────────────────────────────────────────
WAZUH_MCP_AUTH_MODE=bearer
# Generate: openssl rand -hex 32
AUTH_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
# Generate: echo "wazuh_$(openssl rand -hex 20)"
MCP_API_KEY=wazuh_CHANGE_ME_generate_with_openssl_rand_hex_20

# ── OpenAI ───────────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_API_KEY

# ── Threat Intel API Keys ─────────────────────────────────────────────
# VirusTotal free key: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=YOUR_VIRUSTOTAL_API_KEY
# AbuseIPDB free key: https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=YOUR_ABUSEIPDB_API_KEY
# Shodan (optional) — used for IOC port/vuln/service enrichment
# Free API key: https://account.shodan.io/
SHODAN_API_KEY=YOUR_SHODAN_API_KEY
# OTX AlienVault — IOC enrichment + threat feed (all indicator types)
# Free account: https://otx.alienvault.com/api
OTX_API_KEY=YOUR_OTX_API_KEY

# ── Extended Threat Intel (Artifacts & IOC Intelligence module) ───
# GreyNoise — IP noise/classification (free community tier available)
# https://www.greynoise.io/plans/community
GREYNOISE_API_KEY=
# URLScan.io — URL/domain sandbox (free tier: 5000 searches/month)
# https://urlscan.io/user/register
URLSCAN_API_KEY=
# Hybrid Analysis — file/hash sandbox (free community key)
# https://www.hybrid-analysis.com/apikeys/info
HYBRID_ANALYSIS_API_KEY=
# MISP — self-hosted threat intelligence platform
MISP_URL=
MISP_API_KEY=
# OpenCTI — open cyber threat intelligence platform
OPENCTI_URL=
OPENCTI_API_KEY=
# CrowdSec — crowdsourced IP reputation
# https://app.crowdsec.net/settings/api-keys
CROWDSEC_API_KEY=

# ── Mistral AI (optional — used by LangChain agent for cheap triage) ───
# Free tier: https://console.mistral.ai/
MISTRAL_API_KEY=YOUR_MISTRAL_API_KEY

# ── LangChain Agent ────────────────────────────────────────────
# Internal token for webapp→LangChain calls. Generate: openssl rand -hex 24
LANGCHAIN_INTERNAL_TOKEN=CHANGE_ME_generate_with_openssl_rand_hex_24

# ── Neo4j UEBA ────────────────────────────────────────────────
# Community Edition — free forever. Browser UI at http://YOUR_SERVER_IP:7474
# Generate: openssl rand -hex 16
NEO4J_PASSWORD=CHANGE_ME_neo4j_password

# ── Qdrant Vector Database ────────────────────────────────────────────
# Optional API key for Qdrant (leave empty to run without auth — OK for internal-only)
# Generate: openssl rand -hex 24
QDRANT_API_KEY=

# ── RAG / Knowledge Base ──────────────────────────────────────────────
# API key required by rag-retrieval and knowledge-ingestion endpoints.
# Leave empty to allow unauthenticated access (only do this on isolated networks).
# Generate: openssl rand -hex 24
RAG_API_KEY=CHANGE_ME_generate_with_openssl_rand_hex_24

# ── Threat Hunt Scheduler ─────────────────────────────────────────────
# Set to false to disable the background threat hunting cron scheduler
HUNT_SCHEDULER_ENABLED=true

# ── Build metadata ────────────────────────────────────────────────────
BUILD_DATE=unknown
