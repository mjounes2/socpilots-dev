# Environment files — copy .env.template and fill values on the server
.env
*.env
.env.*
!.env.template
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Go binaries — never commit compiled artifacts
thehive-mcp-new/**/thehive-mcp
thehive-mcp-new/**/thehive-mcp-server
thehive-mcp-new/**/main

# Tarballs / release bundles — build artefacts, not source
*.tar
*.tar.gz
*.zip

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.idea/
.vscode/
*.swp
*.swo

# Claude Code local settings (may contain credentials)
.claude/settings.local.json

# Logs
*.log
logs/
